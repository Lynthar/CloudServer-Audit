# Plant: dev.tty.ldisc_autoload=1 (re-opens the CVE-2019-13272 surface).
# Doubles as a regression test for the dev.* filter fix in
# _kernel_audit_kernel_params — pre-fix the audit loop's regex was
# ^(kernel\.|fs\.), so any dev.* entry was silently dropped before
# even being checked. This case will FAIL (id not surfaced at all)
# if the filter ever regresses.
TEST_DESC="dev.tty.ldisc_autoload=1 surfaces in kernel.kernel_params_weak"
EXPECT_ID="kernel.kernel_params_weak"
EXPECT_STATUS="failed"
EXPECT_DESC_CONTAINS="dev.tty.ldisc_autoload"
MODULE="kernel"

_PARAM="dev.tty.ldisc_autoload"
_ORIG=""

precheck() {
    [[ -f /proc/sys/dev/tty/ldisc_autoload ]]
}

mutate() {
    _ORIG=$(sysctl -n "$_PARAM" 2>/dev/null || echo "")
    sysctl -w "${_PARAM}=1" >/dev/null 2>&1
    return 0
}

restore() {
    sysctl -w "${_PARAM}=${_ORIG:-0}" >/dev/null 2>&1
    return 0
}
