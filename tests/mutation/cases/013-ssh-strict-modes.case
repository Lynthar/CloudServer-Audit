# Plant: disable StrictModes (skip permission checks on ~/.ssh and host keys).
# Expect: ssh.strict_modes_disabled — Lynis SSH-7408 addition.
TEST_DESC="SSH StrictModes=no triggers ssh.strict_modes_disabled"
EXPECT_ID="ssh.strict_modes_disabled"
EXPECT_STATUS="failed"
MODULE="ssh"

_DROPIN="/etc/ssh/sshd_config.d/99-vpssec-mutation-test.conf"
_SERVICE=""
_pick_service() {
    if systemctl list-unit-files ssh.service &>/dev/null; then _SERVICE="ssh"
    elif systemctl list-unit-files sshd.service &>/dev/null; then _SERVICE="sshd"
    fi
}

mutate() {
    _pick_service
    printf 'StrictModes no\n' > "$_DROPIN"
    chmod 644 "$_DROPIN"
    [[ -n "$_SERVICE" ]] && systemctl reload "$_SERVICE" >/dev/null 2>&1
    return 0
}

restore() {
    rm -f "$_DROPIN"
    [[ -n "$_SERVICE" ]] && systemctl reload "$_SERVICE" >/dev/null 2>&1
    return 0
}
