# Plant: turn off IgnoreRhosts (re-enables legacy rhosts trust).
# Expect: ssh.ignore_rhosts_disabled — Lynis-cross-check addition.
TEST_DESC="SSH IgnoreRhosts=no triggers ssh.ignore_rhosts_disabled"
EXPECT_ID="ssh.ignore_rhosts_disabled"
EXPECT_STATUS="failed"
MODULE="ssh"

_DROPIN="/etc/ssh/sshd_config.d/99-vpssec-mutation-test.conf"
_SERVICE=""
_pick_service() {
    if systemctl list-unit-files ssh.service &>/dev/null; then _SERVICE="ssh"
    elif systemctl list-unit-files sshd.service &>/dev/null; then _SERVICE="sshd"
    fi
}

mutate() {
    _pick_service
    printf 'IgnoreRhosts no\n' > "$_DROPIN"
    chmod 644 "$_DROPIN"
    [[ -n "$_SERVICE" ]] && systemctl reload "$_SERVICE" >/dev/null 2>&1
    return 0
}

restore() {
    rm -f "$_DROPIN"
    [[ -n "$_SERVICE" ]] && systemctl reload "$_SERVICE" >/dev/null 2>&1
    return 0
}
