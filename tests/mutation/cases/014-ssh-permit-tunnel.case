# Plant: enable PermitTunnel (allows tun/tap forwarding — network pivot).
# Expect: ssh.permit_tunnel_enabled — Lynis SSH-7408 addition.
TEST_DESC="SSH PermitTunnel=yes triggers ssh.permit_tunnel_enabled"
EXPECT_ID="ssh.permit_tunnel_enabled"
EXPECT_STATUS="failed"
MODULE="ssh"

_DROPIN="/etc/ssh/sshd_config.d/99-vpssec-mutation-test.conf"
_SERVICE=""
_pick_service() {
    if systemctl list-unit-files ssh.service &>/dev/null; then _SERVICE="ssh"
    elif systemctl list-unit-files sshd.service &>/dev/null; then _SERVICE="sshd"
    fi
}

mutate() {
    _pick_service
    printf 'PermitTunnel yes\n' > "$_DROPIN"
    chmod 644 "$_DROPIN"
    [[ -n "$_SERVICE" ]] && systemctl reload "$_SERVICE" >/dev/null 2>&1
    return 0
}

restore() {
    rm -f "$_DROPIN"
    [[ -n "$_SERVICE" ]] && systemctl reload "$_SERVICE" >/dev/null 2>&1
    return 0
}
