# Plant: enable SSH password authentication globally.
# Expect: ssh.password_auth_enabled at HIGH severity.
TEST_DESC="SSH PasswordAuthentication=yes triggers ssh.password_auth_enabled"
EXPECT_ID="ssh.password_auth_enabled"
EXPECT_STATUS="failed"
EXPECT_SEVERITY="high"
MODULE="ssh"

_DROPIN="/etc/ssh/sshd_config.d/99-vpssec-mutation-test.conf"
_SERVICE=""
_pick_service() {
    if systemctl list-unit-files ssh.service &>/dev/null; then _SERVICE="ssh"
    elif systemctl list-unit-files sshd.service &>/dev/null; then _SERVICE="sshd"
    fi
}

mutate() {
    _pick_service
    printf 'PasswordAuthentication yes\n' > "$_DROPIN"
    chmod 644 "$_DROPIN"
    [[ -n "$_SERVICE" ]] && systemctl reload "$_SERVICE" >/dev/null 2>&1
    return 0
}

restore() {
    rm -f "$_DROPIN"
    [[ -n "$_SERVICE" ]] && systemctl reload "$_SERVICE" >/dev/null 2>&1
    return 0
}
